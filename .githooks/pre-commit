#!/bin/bash
# Auto-bump SoundShade version on every commit that touches shipping code/resources.
#
# Version format: YYMMDD.HHmm (24h), stamped at commit time — e.g. 260628.1405.
# Both CFBundleShortVersionString and CFBundleVersion are set to this same value.
#
# Skips doc/meta-only commits (CLAUDE.md, README, LICENSE, *.md, .githooks, etc.)
# so version churn only happens for real app changes.
#
# Set SKIP_VERSION_BUMP=1 to bypass (e.g. release/merge commits).

set -e

[ "$SKIP_VERSION_BUMP" = "1" ] && exit 0

PLIST="Sources/SoundShade/Resources/Info.plist"
PB="/usr/libexec/PlistBuddy"

# Staged files in this commit.
STAGED=$(git diff --cached --name-only)
[ -z "$STAGED" ] && exit 0

# Does this commit touch anything that ships in the app?
SHIPPING=$(echo "$STAGED" | grep -E '^(Sources/|Resources/|.*\.swift$|Package\.swift|build_app\.sh)' || true)
[ -z "$SHIPPING" ] && exit 0

# If the only shipping change is the plist itself (e.g. a manual bump), don't double-bump.
NON_PLIST=$(echo "$SHIPPING" | grep -v "^${PLIST}$" || true)
[ -z "$NON_PLIST" ] && exit 0

[ -f "$PLIST" ] || exit 0

old_version=$("$PB" -c "Print CFBundleShortVersionString" "$PLIST")
new_version=$(date +"%y%m%d.%H%M")

"$PB" -c "Set :CFBundleShortVersionString $new_version" "$PLIST"
"$PB" -c "Set :CFBundleVersion $new_version" "$PLIST"
git add "$PLIST"

echo "🔖 Version bumped: $old_version -> $new_version"
